{
  "name": "@ephemeralenv/core",
  "version": "0.1.0",
  "description": "Core runner and CLI for disposable local QA environments.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "ephemeralenv": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
